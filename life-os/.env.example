# Copy this to .env and fill in your values
DATABASE_URL=postgresql://lifeos:lifeos@localhost:5432/lifeos
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Anthropic Claude API (required for AI features)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Encryption key for sensitive fields (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me-generate-a-real-fernet-key
