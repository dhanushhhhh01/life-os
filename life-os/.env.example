# ============================================================
# Life OS - Environment Variables Template
# Copy this to .env and fill in your values
# ============================================================

# ----- Database -----
DATABASE_URL=postgresql://lifeos:lifeos@localhost:5432/lifeos
# For local SQLite dev: DATABASE_URL=sqlite:///./life_os.db

# ----- Auth / JWT -----
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ----- Encryption (Fernet) -----
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# ----- Anthropic Claude API -----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ----- Cache (optional Redis) -----
# Leave unset to use in-memory cache (default)
# REDIS_URL=redis://localhost:6379/0
# On Railway: add Redis plugin and it sets REDIS_URL automatically

# ----- CORS -----
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# ----- Environment -----
ENVIRONMENT=development
# ENVIRONMENT=production

# ----- Railway / Deployment -----
# PORT is set automatically by Railway; override if needed:
# PORT=8000
